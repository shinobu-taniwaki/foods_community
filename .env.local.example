# ============================================================
# ローカル開発用 環境変数テンプレート
# このファイルを `.env.local` にコピーして使用する。
#
# 値は `supabase start` 実行後に `supabase status` で表示される
# 「API URL / anon key / service_role key」を貼り付ける。
# ============================================================

# --- Supabase（ローカル Self-hosted）---
# 既定の 54321 は別プロジェクトが使用中のため、本プロジェクトは 54421 を使用
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase status の anon key を貼る>
SUPABASE_SERVICE_ROLE_KEY=<supabase status の service_role key を貼る>

# --- メール送信（Resend）開発では空でも可（API キー空 = 送信スキップ）---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
# 未設定ならアプリ名を使用
RESEND_FROM_NAME=
# 返信先（サポート窓口）。未設定なら FROM を使用
RESEND_REPLY_TO=
# フッター等に表示するサポートメール。未設定なら REPLY_TO → FROM の順で使用
NEXT_PUBLIC_SUPPORT_EMAIL=

# --- β期間 ---
NEXT_PUBLIC_BETA_MODE=true
NEXT_PUBLIC_BETA_END_DATE=2026-07-31

# --- Google フォーム URL（開発では空でも可。詳細は details/google-forms.md）---
NEXT_PUBLIC_FORM_PLAN_UPGRADE=
NEXT_PUBLIC_FORM_WITHDRAWAL=
NEXT_PUBLIC_FORM_INQUIRY=
NEXT_PUBLIC_FORM_BUG_REPORT=
NEXT_PUBLIC_FORM_SEMINAR=

# --- Google フォーム prefill 用 entry ID（任意。各フォームの「事前入力された URL を取得」から）---
NEXT_PUBLIC_FORM_PLAN_ENTRY_NAME=
NEXT_PUBLIC_FORM_PLAN_ENTRY_EMAIL=
NEXT_PUBLIC_FORM_PLAN_ENTRY_CURRENT_PLAN=
NEXT_PUBLIC_FORM_WITHDRAWAL_ENTRY_NAME=
NEXT_PUBLIC_FORM_WITHDRAWAL_ENTRY_EMAIL=
NEXT_PUBLIC_FORM_WITHDRAWAL_ENTRY_CURRENT_PLAN=

# --- アクセス解析・エラー監視（開発では空でも可）---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
SENTRY_DSN=
